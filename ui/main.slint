import { FilledButton, ElevatedCard } from "@material";

export component App inherits Window {
    property <int> count: 0;

    ElevatedCard {
        width: 90%;
        height: 90%;
        FilledButton {
            text: "Count: " + count;
            icon: @image-url("lucide/file-play.svg");
            clicked => {
                count += 1;
            }
        }
    }
}